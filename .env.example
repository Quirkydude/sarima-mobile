# Copy this file to .env and fill in your computer's LAN IP.
# "localhost" only works when you run the app in a Simulator on the SAME
# machine as the backend. On a real phone via Expo Go, localhost means the
# PHONE, not your computer — so it will look like the app "can't connect."
#
# Find your LAN IP:
#   Mac:     ipconfig getifaddr en0
#   Linux:   hostname -I
#   Windows: ipconfig   (look for "IPv4 Address" under your Wi-Fi adapter)
#
# Phone and computer must be on the same Wi-Fi network.
EXPO_PUBLIC_API_URL=http://localhost:8000
